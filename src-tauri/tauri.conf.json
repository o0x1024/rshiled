{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rshield",
  "version": "0.1.0",
  "identifier": "com.rshield.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "rshield",
        "minWidth": 1400,
        "minHeight": 900,
        "center": true,
        "visible": false
      },
      {
        "minWidth": 1400,
        "minHeight": 900,
        "center": true,
        "url": "splashscreen.html", 
        "label": "splashscreen",
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
